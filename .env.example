# Copy this file to .env and fill in the values. Never commit your real .env.

# From @BotFather after you create your bot.
BOT_TOKEN=123456789:your-token-here

# Optional: numeric Telegram user IDs of facilitators, comma separated.
# These people can run facil-only commands even if they aren't group admins.
# Get your ID from @userinfobot.
FACILITATOR_IDS=

# Optional: where to keep the SQLite file (defaults to bot.db next to the code).
# DB_PATH=bot.db
